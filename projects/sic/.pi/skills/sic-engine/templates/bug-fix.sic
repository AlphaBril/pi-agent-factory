file: "[file path]"
action: modify
purpose: "Fix [describe the bug in one sentence]"

depends_on: []

context: |
  [Describe the bug: what happens, what should happen, where it occurs]

modifications:
  - "Identify root cause in [specific function/line]"
  - "Apply minimal fix: [describe the fix]"
  - "Verify fix handles the edge case: [describe edge case]"

location_hints:
  - "[function name or line number where the bug exists]"

new_imports: []
new_exports: []

constraints:
  - MINIMAL change — fix the bug, nothing else
  - no refactoring
  - "no 'while I'm here' improvements"
  - no new abstractions
  - no changing function signatures
  - no moving code between files
  - preserve exact whitespace/formatting around the fix

done_when:
  - "bug is fixed: [describe how to verify]"
  - lint passes
  - types pass
  - existing tests pass
  - no unrelated files changed
