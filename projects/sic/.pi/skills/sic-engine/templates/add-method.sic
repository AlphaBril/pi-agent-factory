file: "[directory/file.ts]"
action: modify
purpose: "[what this method does]"

depends_on: []

context: |
  [Why this method is needed, what calls it]

modifications:
  - "Add method [methodName]([params]): [returnType]"
  - "[step 1 of behavior]"
  - "[step 2 of behavior]"

location_hints:
  - "Add after [existing method name] (around line N)"

new_imports: []

new_exports: []

constraints:
  - follow lint rules
  - follow existing methods' style in the same file
  - no refactoring existing code
  - no changing existing method signatures
  - no unrelated edits
  - no new files

done_when:
  - lint passes
  - types pass
  - existing tests still pass
  - new method is callable from outside the class
