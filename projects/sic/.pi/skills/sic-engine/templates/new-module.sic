file: "[directory/new-file.ts]"
action: create
purpose: "[describe what this module does in one sentence]"

depends_on: []

context: |
  [Why this module is needed, what calls it, where it fits in the architecture]

modifications:
  - "Create class/module [Name] extending [BaseClass]"
  - "Implement [method1]() — [what it does]"
  - "Implement [method2]() — [what it does]"
  - "Add named export"

location_hints: []

new_imports:
  - "import { BaseClass } from './base'"
  - "import type { Config } from '../types'"

new_exports:
  - "[ModuleName]"

constraints:
  - follow lint rules
  - follow neighboring module style
  - no new abstractions beyond what's specified
  - no refactoring existing code
  - no unrelated edits
  - no external dependencies

done_when:
  - lint passes
  - types pass
  - exports added to index
  - module can be instantiated with mock dependencies
